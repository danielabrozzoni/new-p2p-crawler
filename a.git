 `--i2p-concurrency` (32).
 
 **Crawler behavior**:
diff --git a/src/crawler.rs b/src/crawler.rs
index 538c02d..1420554 100644
--- a/src/crawler.rs
+++ b/src/crawler.rs
@@ -242,7 +242,14 @@ impl Crawler {
             Ok(c) => c,
             Err(e) => {
                 tracing::debug!("connect failed for {}: {e}", key.render());
-                self.finish(key, NodeState::Unreachable);
+                // Retry like any other transient failure (Section 6.2): a connect
+                // timeout/refusal can be self-inflicted (e.g. a saturated worker
+                // pool), not necessarily a dead peer.
+                if attempt < max_attempts {
+                    self.requeue(key, t);
+                } else {
+                    self.finish(key, NodeState::Unreachable);
+                }
                 return;
             }
         };
